{
  "expo": {
    "name": "Upmind",
    "slug": "upmind",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "upmind",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/brain.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0F1C"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.upmind.app",
      "buildNumber": "1"
    },
    "android": {
      "package": "com.upmind.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./icon.svg",
        "backgroundColor": "#0A0F1C"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./icon.svg"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-haptics",
      "expo-splash-screen"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      }
    }
  }
}
